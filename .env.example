# Webhook de Make.com que recibe los registros de la masterclass.
# Esta variable SOLO se lee en el servidor (API route /api/register).
# 1. Entra a Make.com -> crear nuevo escenario -> webhook "Custom webhook"
# 2. Copia la URL que te entrega Make
# 3. Pegala aca con el nombre MAKE_WEBHOOK_URL

MAKE_WEBHOOK_URL=https://hook.us2.make.com/TU-WEBHOOK-AQUI

# ============================================================
# Meta Píxel + Conversions API (CAPI)
# ============================================================
# Pixel ID / Dataset ID. Es PÚBLICO (se usa en el navegador). El prefijo
# NEXT_PUBLIC_ es obligatorio para que Next lo exponga al cliente.
NEXT_PUBLIC_META_PIXEL_ID=TU-PIXEL-ID

# Token de la Conversions API. Es SECRETO: solo se lee en el servidor.
# Se genera en Meta Events Manager -> tu conjunto de datos -> Configuración
# -> Conversions API -> Generar token de acceso.
META_CAPI_ACCESS_TOKEN=TU-ACCESS-TOKEN

# (Opcional) Código de "Test Events" para verificar en Events Manager antes
# de pasar a producción. Déjalo vacío o bórralo cuando termines de probar.
META_TEST_EVENT_CODE=
