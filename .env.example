# Webhook de Make.com que recibe los registros de la masterclass.
# Esta variable SOLO se lee en el servidor (API route /api/register).
# 1. Entra a Make.com -> crear nuevo escenario -> webhook "Custom webhook"
# 2. Copia la URL que te entrega Make
# 3. Pegala aca con el nombre MAKE_WEBHOOK_URL

MAKE_WEBHOOK_URL=https://hook.us2.make.com/TU-WEBHOOK-AQUI
